# ─── AI API Configuration ────────────────────────────────────────────
# AI_API_URL: The external AI API endpoint URL (server-side only, never exposed to client).
AI_API_URL="https://api.siputzx.my.id/api/ai/gptoss120b"

# AI_API_KEY: API key for the external AI service (if required).
# SECURITY: This key is NEVER sent to the client — only used in server.ts.
AI_API_KEY=""

# ─── Server Configuration ────────────────────────────────────────────
# PORT: The port where the Express server runs.
PORT=3000

# NODE_ENV: "development" or "production".
# In production, CORS is stricter, HSTS is enabled, and error details are hidden.
NODE_ENV="development"

# ─── CORS (Cross-Origin Resource Sharing) ────────────────────────────
# ALLOWED_ORIGINS: Comma-separated list of origins permitted to call /api/chat.
# In production, set this to your deployed domain(s) only (e.g., "https://nalar.ai").
# In development, "http://localhost:3000" is allowed by default.
ALLOWED_ORIGINS="http://localhost:3000,https://nalar-ai-tau.vercel.app,https://nalar-ai.web.id"

# ─── Rate Limiting ───────────────────────────────────────────────────
# RATE_LIMIT_WINDOW: Time window in milliseconds for rate limiting on /api/chat.
RATE_LIMIT_WINDOW=60000

# RATE_LIMIT_MAX: Maximum number of requests per IP within the rate limit window.
RATE_LIMIT_MAX=20

# ─── Legacy (unused, kept for reference) ─────────────────────────────
# GEMINI_API_KEY: Previously used for direct client-side Gemini API calls.
# SECURITY: This is NO LONGER injected into the client bundle.
# All AI calls now go through the server proxy at /api/chat.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# APP_URL="MY_APP_URL"
