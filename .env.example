# ─── Cerebras API Configuration ───────────────────────────────────────
# CEREBRAS_API_KEY: API key for Cerebras Cloud SDK (server-side only, never exposed to client).
# SECURITY: This key is NEVER sent to the client — only used in server.ts / api/chat.ts.
# Get your key from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY="YOUR_CEREBRAS_API_KEY_HERE"

# ─── Server Configuration ────────────────────────────────────────────
# PORT: The port where the Express server runs.
PORT=3000

# NODE_ENV: "development" or "production".
# In production, CORS is stricter, HSTS is enabled, and error details are hidden.
NODE_ENV="development"

# ─── CORS (Cross-Origin Resource Sharing) ────────────────────────────
# ALLOWED_ORIGINS: Comma-separated list of origins permitted to call /api/chat.
# In production, set this to your deployed domain(s) only (e.g., "https://nalar.ai").
# In development, "http://localhost:3000" is allowed by default.
ALLOWED_ORIGINS="http://localhost:3000,https://nalar-ai-tau.vercel.app,https://nalar-ai.web.id"

# ─── Rate Limiting ───────────────────────────────────────────────────
# RATE_LIMIT_WINDOW: Time window in milliseconds for rate limiting on /api/chat.
RATE_LIMIT_WINDOW=60000

# RATE_LIMIT_MAX: Maximum number of requests per IP within the rate limit window.
RATE_LIMIT_MAX=20
